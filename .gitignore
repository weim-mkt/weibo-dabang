# ==============================================================================
# .gitignore for Weibo Dabang JMR R&R
# ==============================================================================

# Symlinks (target paths are machine-specific; symlinks themselves not tracked)
claude-code-my-workflow
data/raw

# LaTeX build artifacts (generated when compiling locally; Overleaf compiles remotely)
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
.Rdata
*.Rproj

# Stata
*.dta
!data/processed/.gitkeep

# OS files
.DS_Store
Thumbs.db

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/
CLAUDE.local.md

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Quarto rendering artifacts
.quarto/

# Environment files (potential secrets)
.env
.envrc

# quality_reports/ — per-project session logs, plans, specs, merges, decisions.
# Directory skeleton is tracked via .gitkeep; content is project-internal and
# typically not pushed to a shared remote.
quality_reports/plans/*
quality_reports/specs/*
quality_reports/session_logs/*
quality_reports/merges/*
quality_reports/decisions/*
!quality_reports/plans/.gitkeep
!quality_reports/specs/.gitkeep
!quality_reports/session_logs/.gitkeep
!quality_reports/merges/.gitkeep
!quality_reports/decisions/.gitkeep

# Analysis outputs (regenerated by R scripts; large + ephemeral)
# Use trailing /* so the `.gitkeep` exception below actually takes effect
# (ignoring the parent dir would short-circuit the negation).
code/_outputs/*
data/processed/*
!code/_outputs/.gitkeep
!data/processed/.gitkeep

# Figures intermediate (publication-ready PDFs go in Figures/ or overleaf-weibo-dabang/figure/)
Figures/_intermediate/
